{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "{.venv/**,.deps/**,.pip-cache/**,.pip-tmp/**,.tmp/**,npm_cache_test/**,frontend/node_modules/**,frontend/.npm-cache/**,frontend/dist/**,backend/tests/**,__pycache__/**,**/*.pyc}"
    }
  }
}
