{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "maxDuration": 60,
      "excludeFiles": "{.venv/**,.deps/**,.pip-cache/**,.pip-tmp/**,.tmp/**,npm_cache_test/**,frontend/**,brand/**,backend/tests/**,__pycache__/**,**/*.pyc}"
    }
  }
}
